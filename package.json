{
  "name": "limitless-cli",
  "version": "0.1.0",
  "description": "CLI for the Limitless TCG public API (tournaments, games, and more).",
  "type": "module",
  "engines": {
    "node": ">=18.17"
  },
  "bin": {
    "ltcg": "./bin/ltcg.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "NEXT_STEPS.md"
  ],
  "scripts": {
    "build": "tsc -p .",
    "dev": "tsc -w -p .",
    "lint": "biome check ./src",
    "format": "biome format --write ./src",
    "typecheck": "tsc --noEmit -p .",
    "prepublishOnly": "pnpm build && node scripts/chmod-bin.mjs",
    "release": "changeset publish"
  },
  "keywords": [
    "limitless-cli",
    "limitless",
    "tcg",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "env-paths": "^3.0.0",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.9",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.2"
  }
}
